{
  "name": "sim-center-agent",
  "version": "1.0.0",
  "description": "Agent local pour Sim Center Manager",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "pkg": {
    "targets": [
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "outputPath": "./exe",
    "assets": [
      ".env.example"
    ]
  },
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "build:exe": "npm run build && pkg . --out-path ./exe"
  },
  "dependencies": {
    "@types/blessed": "^0.1.27",
    "blessed": "^0.1.81",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "nodemon": "^3.1.3",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
