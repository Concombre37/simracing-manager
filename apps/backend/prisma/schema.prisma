generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  password  String
  role      String   @default("technician")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Station {
  id          String    @id @default(uuid()) @db.Uuid
  stationId   String    @unique @map("station_id")
  name        String
  apiKeyHash  String?   @map("api_key_hash")
  version     String?
  localIp     String?   @map("local_ip")
  macAddress  String?   @map("mac_address")
  lastSeenAt  DateTime? @map("last_seen_at")
  status      String    @default("offline")
  config      Json?
  content     Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sessions        Session[]
  dedicatedServers DedicatedServer[]
  contentPreviews ContentPreview[]
  blankingMedia   BlankingMedia[]

  @@map("stations")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  stationId String    @map("station_id") @db.Uuid
  config    Json
  status    String    @default("pending")
  startedAt DateTime? @map("started_at")
  endedAt   DateTime? @map("ended_at")
  result    Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  telemetryFiles TelemetryFile[]

  @@map("sessions")
}

model TelemetryFile {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  fileName  String   @map("file_name")
  sizeBytes Int      @map("size_bytes")
  content   Bytes?
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("telemetry_files")
}

model ContentPackage {
  id          String   @id @default(uuid()) @db.Uuid
  type        String
  name        String
  version     String
  archiveUrl  String   @map("archive_url")
  checksum    String?
  isRequired  Boolean  @default(true) @map("is_required")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([type, name, version])
  @@map("content_packages")
}

model DedicatedServer {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  stationId      String    @map("station_id") @db.Uuid
  station        Station   @relation(fields: [stationId], references: [id], onDelete: Cascade)
  track          String
  trackLayout    String?   @map("track_layout")
  cars           String[]
  maxClients     Int       @default(10) @map("max_clients")
  password       String?
  rconPassword   String?   @map("rcon_password")
  config         Json?
  status         String    @default("stopped")
  serverDir      String?   @map("server_dir")
  udpPort        Int?      @map("udp_port")
  tcpPort        Int?      @map("tcp_port")
  httpPort       Int?      @map("http_port")
  startedAt      DateTime? @map("started_at")
  endedAt        DateTime? @map("ended_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("dedicated_servers")
}

model ContentPreview {
  id        String   @id @default(uuid()) @db.Uuid
  stationId String   @map("station_id") @db.Uuid
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  type      String
  acId      String   @map("ac_id")
  name      String
  data      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([stationId, type, acId])
  @@map("content_previews")
}

model BlankingMedia {
  id        String   @id @default(uuid()) @db.Uuid
  stationId String   @map("station_id") @db.Uuid
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String   @map("mime_type")
  sizeBytes Int      @map("size_bytes")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([stationId, order])
  @@map("blanking_media")
}
