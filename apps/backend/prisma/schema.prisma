generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  password  String
  role      String   @default("technician")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Station {
  id          String    @id @default(uuid()) @db.Uuid
  stationId   String    @unique @map("station_id")
  name        String
  apiKeyHash  String?   @map("api_key_hash")
  version     String?
  localIp     String?   @map("local_ip")
  lastSeenAt  DateTime? @map("last_seen_at")
  status      String    @default("offline")
  config      Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sessions Session[]

  @@map("stations")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  stationId String    @map("station_id") @db.Uuid
  config    Json
  status    String    @default("pending")
  startedAt DateTime? @map("started_at")
  endedAt   DateTime? @map("ended_at")
  result    Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  telemetryFiles TelemetryFile[]

  @@map("sessions")
}

model TelemetryFile {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  fileName  String   @map("file_name")
  sizeBytes Int      @map("size_bytes")
  content   Bytes?
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("telemetry_files")
}

model ContentPackage {
  id          String   @id @default(uuid()) @db.Uuid
  type        String
  name        String
  version     String
  archiveUrl  String   @map("archive_url")
  checksum    String?
  isRequired  Boolean  @default(true) @map("is_required")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([type, name, version])
  @@map("content_packages")
}

model DedicatedServer {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  host           String
  port           Int
  password       String?
  rconPassword   String?  @map("rcon_password")
  isLocal        Boolean  @default(false) @map("is_local")
  processName    String?  @map("process_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("dedicated_servers")
}
