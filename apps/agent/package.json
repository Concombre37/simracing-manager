{
  "name": "@simracing/agent",
  "version": "2.2.22",
  "private": true,
  "description": "Local agent for SimRacing Manager stations",
  "main": "./dist/index.js",
  "bin": {
    "simracing-agent": "./dist/index.js"
  },
  "scripts": {
    "prebuild": "node scripts/write-version.js",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "prepackage": "npm run build",
    "package": "pkg . --out-path exe",
    "prepackage:win": "npm run build && node scripts/patch-koffi-for-pkg.js",
    "package:win": "pkg . --targets node18-win-x64 --out-path exe",
    "postpackage:win": "node scripts/copy-koffi-native.js"
  },
  "dependencies": {
    "@simracing/shared": "*",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "koffi": "^2.16.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0",
    "socket.io-client": "^4.7.5",
    "wake_on_lan": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "pkg": "^5.8.1",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "lua_app/**/*",
      "assets/**/*",
      "node_modules/koffi/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "exe"
  }
}
