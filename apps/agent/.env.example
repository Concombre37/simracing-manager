# URL du backend SimRacing Manager
SERVER_URL=https://simracing.hytlabs.com

# Identifiant unique de ce poste (minuscules, chiffres, tirets)
STATION_ID=poste-1

# Nom affiché dans le dashboard
STATION_NAME=Poste 1

# Clé API fournie par le dashboard (Station → "Nouvelle clé API")
API_KEY=sk_...

# Mode de lancement : cm (Content Manager) ou ac (Assetto Corsa direct)
LAUNCH_MODE=cm

# Chemin vers le dossier Documents Assetto Corsa (optionnel, auto-détecté)
# DOCUMENTS_PATH=C:\Users\TonNom\Documents\Assetto Corsa

# Chemin vers acServer.exe si serveur local (optionnel)
# AC_PATH=C:\Program Files (x86)\Steam\steamapps\common\assettocorsa\server
